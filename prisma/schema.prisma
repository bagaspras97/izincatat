// Prisma Schema — Izin Catat
// Bot pencatatan keuangan pribadi WhatsApp

generator client {
  provider = "prisma-client-js"
  output   = "../web/node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Tabel users — menyimpan data pengguna WhatsApp
model User {
  id          Int         @id @default(autoincrement())
  publicId    String      @unique @default(cuid()) @map("public_id")
  nomorWa     String      @unique @map("nomor_wa")
  nama        String?
  createdAt   DateTime    @default(now()) @map("created_at")
  isActive    Boolean     @default(true) @map("is_active")
  /// Tier langganan: GRATIS | PRO | COUPLE
  tier        String      @default("GRATIS")
  /// Tanggal berakhir langganan PRO/COUPLE (null = GRATIS atau berlaku seumur hidup)
  tierExpiry  DateTime?   @map("tier_expiry")
  transaksi   Transaksi[]

  @@map("users")
}

/// Tabel transaksi — menyimpan catatan pemasukan & pengeluaran
model Transaksi {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  jenis      String   // "masuk" atau "keluar"
  nominal    Decimal  @db.Decimal(15, 2)
  keterangan String
  kategori   String
  tanggal    DateTime @default(now())
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tanggal])
  // Composite index untuk query dashboard/laporan/kategori: filter userId + tanggal
  @@index([userId, tanggal])
  // Composite index untuk query groupBy jenis + filter userId + tanggal
  @@index([userId, jenis, tanggal])
  @@map("transaksi")
}

/// Tabel settings — konfigurasi aplikasi (key-value)
model Setting {
  key   String @id
  value String

  @@map("settings")
}

/// Tabel dev_expenses — pencatatan pengeluaran pengembangan bot & platform
model DevExpense {
  id        Int      @id @default(autoincrement())
  nama      String
  harga     Decimal  @db.Decimal(15, 2)
  tanggal   DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("dev_expenses")
}
